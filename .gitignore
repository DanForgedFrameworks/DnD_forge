# Python
__pycache__/
*.pyc
.venv/
.venv_forge/
*.egg-info/

# Secrets
.env

# Pulled canonical data (re-fetchable via scripts/fetch_srd_data.py) — fetched SRD only.
/data/srd/*
# ...but our ORIGINAL homebrew overlay (the Hoopak, flavour item actions, language &
# feature descriptions, species traits, standard actions) IS shipped — it's our own
# content, not the copyrighted SRD, and the engine depends on it.
!/data/srd/_homebrew/

# Open-licensed third-party content: generated JSON is regenerated via
# scripts/import_open5e_monsters.py; the licence/attribution text IS committed.
/data/expanded/*.json

# LOCAL-ONLY WALL: owned-book content for personal prototyping. NEVER committed,
# NEVER shipped. Anything under data/local/ stays on this machine only.
/data/local/

# Source rulebook PDFs (copyrighted) — never committed.
/PDFs/
*.pdf

# Pipeline working + output artifacts
/intermediate/
/output/

# OS
Thumbs.db
.DS_Store

# Local download/extract scratch (the front-end is vendored under frontend/ / web/frontend/)
/D&D 5e character generator*/

# local PDF text extraction scratch (book data, never committed)
.extract_tmp/

# 2024 SRD markdown source clone (scratch, regenerate via scripts/convert_srd2024_md.py)
/.srd2024_src/

# Art-style reference images (third-party / copyrighted, collected for direction only — never committed)
/Example images/
